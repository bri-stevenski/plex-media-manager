# ── Required ───────────────────────────────────────────────────────────────────
TMDB_API_KEY=your_tmdb_api_key_here
MUSICBRAINZ_API_KEY=your_musicbrainz_api_key_here

# ── Library paths ───────────────────────────────────────────────────────────────
MEDIA_BASE_DIR=./media
MUSIC_LIBRARY_ROOT=./music

QUEUE_FOLDER=queue
PROCESSING_FOLDER=processing
COMPLETED_FOLDER=completed
FAILED_FOLDER=failed

# ── Plex (optional) ─────────────────────────────────────────────────────────────
# PLEX_URL=http://localhost:32400
# PLEX_TOKEN=your_plex_token_here

# ── OpenSubtitles (optional) ────────────────────────────────────────────────────
# OPENSUBTITLES_API_KEY=your_api_key_here
# OPENSUBTITLES_USERNAME=your_username
# OPENSUBTITLES_PASSWORD=your_password
# SUBTITLE_LANGUAGES=en,es

# ── qBittorrent (optional) ──────────────────────────────────────────────────────
# QBITTORRENT_URL=http://localhost:8080
# QBITTORRENT_USERNAME=admin
# QBITTORRENT_PASSWORD=your_password

# ── Watcher daemon ───────────────────────────────────────────────────────────────
# WATCH_INTERVAL_SECONDS=300

# ── Trakt (optional) ─────────────────────────────────────────────────────────────
# Get a client ID from https://trakt.tv/oauth/applications
# TRAKT_CLIENT_ID=your_client_id
# TRAKT_ACCESS_TOKEN=your_access_token   # only needed for private watchlists

# ── Notifications (optional — any combination works) ─────────────────────────────
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...
# PUSHOVER_TOKEN=your_app_token
# PUSHOVER_USER=your_user_key

# ── Logging ──────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
