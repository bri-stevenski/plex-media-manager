{
  "name": "plex-media-manager",
  "version": "3.0.0",
  "private": true,
  "packageManager": "npm@11.6.2",
  "engines": {
    "node": "25.2.1",
    "npm": "11.6.2"
  },
  "scripts": {
    "setup": "node scripts/setup.js",
    "setup:check": "node scripts/setup.js --check",
    "node:use": "node scripts/node-use.cjs",
    "clean:all": "node scripts/clean.js all",
    "lint": "eslint . --ext .ts,.js,.cjs",
    "lint:fix": "eslint . --ext .ts,.js,.cjs --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "style:check": "npm run lint && npm run format:check",
    "style:fix": "npm run lint:fix && npm run format",
    "type-check": "tsc -p tsconfig.json",
    "build:all": "npm run rename:build",
    "rename:build": "tsc --project tsconfig.rename.json",
    "rename:setup": "npm run setup && npm run rename:build",
    "rename:run": "node dist/rename-media-files.js",
    "rename:dry-run": "node dist/rename-media-files.js --dry-run --log-level DEBUG",
    "rename:debug": "node dist/rename-media-files.js --log-level DEBUG"
  },
  "dependencies": {
    "axios": "^1.13.5",
    "commander": "^14.0.3",
    "dotenv": "^17.3.1",
    "luxon": "^3.7.2",
    "next": "latest",
    "p-limit": "^7.3.0",
    "react": "latest",
    "react-dom": "latest",
    "winston": "^3.14.2"
  },
  "devDependencies": {
    "@types/luxon": "^3.7.1",
    "@types/node": "^25.3.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.56.0",
    "@typescript-eslint/parser": "^8.56.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "prettier": "^3.8.1",
    "ts-node": "^10.9.2",
    "typescript": "latest"
  }
}
