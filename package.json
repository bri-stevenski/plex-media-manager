{
  "name": "plex-media-manager",
  "version": "2.0.0",
  "private": true,
  "scripts": {
    "build:tools": "tsc --project tsconfig.tools.json",
    "rename": "npm run build:tools && node dist/rename-media-files.js",
    "rename:dry-run": "npm run build:tools && node dist/rename-media-files.js --dry-run",
    "rename:debug": "npm run build:tools && node dist/rename-media-files.js --log-level DEBUG",
    "clean": "node -e \"require('fs').rmSync('dist', { recursive: true, force: true })\"",
    "lint": "eslint . --ext .ts,.tsx,.js,.jsx",
    "lint:fix": "eslint . --ext .ts,.tsx,.js,.jsx --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "type-check": "tsc --noEmit",
    "validate": "npm run type-check && npm run lint && npm run format:check"
  },
  "dependencies": {
    "axios": "^1.13.5",
    "commander": "^14.0.3",
    "dotenv": "^17.3.1",
    "luxon": "^3.7.2",
    "next": "latest",
    "p-limit": "^7.3.0",
    "react": "latest",
    "react-dom": "latest"
  },
  "devDependencies": {
    "@types/luxon": "^3.7.1",
    "@types/node": "^25.2.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.56.0",
    "@typescript-eslint/parser": "^8.56.0",
    "eslint": "^8.57.1",
    "eslint-config-next": "latest",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "prettier": "^3.8.1",
    "ts-node": "^10.9.2",
    "typescript": "latest"
  }
}
