{
  "name": "plex-media-manager",
  "version": "3.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.15.9",
  "bin": {
    "plex-movies": "src/agents/cli-movies.ts",
    "plex-tv": "src/agents/cli-tv.ts",
    "plex-music": "src/agents/cli-music.ts",
    "plex-complete": "src/agents/cli-complete.ts"
  },
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "setup": "node scripts/setup.js",
    "setup:check": "node scripts/setup.js --check",
    "node:use": "node scripts/node-use.cjs",
    "clean:all": "node scripts/clean.js all",
    "lint": "eslint . --ext .ts,.js,.cjs",
    "lint:fix": "eslint . --ext .ts,.js,.cjs --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "style:check": "pnpm run lint && pnpm run format:check",
    "style:fix": "pnpm run lint:fix && pnpm run format",
    "type-check": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "rename:build": "tsc --project tsconfig.rename.json",
    "rename:setup": "pnpm run setup && pnpm run rename:build",
    "rename:run": "node dist/agents/cli-media.js",
    "rename:dry-run": "node dist/agents/cli-media.js --dry-run --log-level DEBUG",
    "rename:debug": "node dist/agents/cli-media.js --log-level DEBUG",
    "start:movies": "node dist/agents/cli-movies.js",
    "start:tv": "node dist/agents/cli-tv.js",
    "start:music": "node dist/agents/cli-music.js",
    "start:complete": "node dist/agents/cli-complete.js",
    "build": "tsc --project tsconfig.json && node scripts/write-dist-pkg.cjs",
    "build:all": "pnpm run build",
    "music:run": "node dist/agents/cli-music.js",
    "music:dry-run": "node dist/agents/cli-music.js --dry-run --log-level DEBUG",
    "music:debug": "node dist/agents/cli-music.js --log-level DEBUG",
    "build:executables": "node scripts/build-executables.js",
    "music:build": "tsc --project tsconfig.music.json",
    "music:setup": "pnpm run setup && pnpm run music:build",
    "docker:build": "docker compose build",
    "docker:up": "docker compose up",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f",
    "validate": "harness validate",
    "check-deps": "harness check-deps"
  },
  "dependencies": {
    "axios": "^1.15.2",
    "commander": "^14.0.3",
    "dotenv": "^17.3.1",
    "harness-engineering": "^2.0.0",
    "luxon": "^3.7.2",
    "next": "^15.5.18",
    "p-limit": "^7.3.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "@harness-engineering/cli": "^2.6.1",
    "@harness-engineering/core": "^0.24.0",
    "@harness-engineering/eslint-plugin": "^0.3.0",
    "@types/luxon": "^3.7.1",
    "@types/node": "^25.3.0",
    "@types/react": "18.3.1",
    "@types/react-dom": "18.3.1",
    "@typescript-eslint/eslint-plugin": "^8.56.0",
    "@typescript-eslint/parser": "^8.56.0",
    "@vitest/coverage-v8": "^2",
    "caxa": "^3.0.1",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "prettier": "^3.9.1",
    "ts-node": "^10.9.2",
    "typescript": "latest",
    "vitest": "^2"
  },
  "pnpm": {
    "overrides": {
      "postcss": ">=8.5.10",
      "@anthropic-ai/sdk": ">=0.91.1"
    }
  }
}
